@startuml
hide footbox
actor "Admin/User" as User
boundary "FaceCheck.jsx" as UI
control "MediaPipe" as MP
control "ONNX Runtime" as ONNX
control "process_attendance" as API
entity "NhanVien" as DB

User -> UI: Đưa khuôn mặt vào camera
activate UI
UI -> MP: Tải model FaceDetector & FaceLandmarker
UI -> ONNX: Tải model mobilefacenet_insightface.onnx

loop Phát hiện khuôn mặt
    UI -> MP: detectForVideo()
    MP --> UI: Kết quả
end

UI --> User: Giữ yên 2 giây
UI --> User: Hãy chớp mắt! (7 giây)

loop Blink Detection
    UI -> MP: detectForVideo()
    MP --> UI: Face landmarks
    UI -> UI: Tính EAR
end

alt Chớp mắt thành công
    UI -> ONNX: getFaceEmbedding(alignedFace)
    ONNX --> UI: embedding [512 float]
    UI -> API: Gửi embedding
    activate API
    
    API -> DB: Tìm nhân viên (Cosine Match)
    activate DB
    DB --> API: Nhân viên, Score
    deactivate DB

    alt Không tìm thấy (Score < 0.75)
         API --> UI: Lỗi: Không nhận diện được
         UI --> User: Yêu cầu thử lại
    else Tìm thấy nhân viên
        API -> DB: Kiểm tra trạng thái (Work Status)
        activate DB
        DB --> API: Status
        deactivate DB
        
        alt Trạng thái != WORKING
            API --> UI: Lỗi: Nhân viên đã nghỉ/không hoạt động
        else Trạng thái OK
            API -> DB: Lấy bản ghi chấm công hôm nay
            activate DB
            DB --> API: Bản ghi (hoặc tạo mới)
            deactivate DB
            
            alt Chưa Check-in (check_in_time is Null)
                API -> DB: Cập nhật Check-in (Time & Status)
                note right: ON_TIME hoặc LATE
            else Đã Check-in
                API -> DB: Cập nhật Check-out (Time & Status)
                note right: EARLY hoặc NORMAL
            end
            
            API -> DB: Lưu dữ liệu
            activate DB
            DB --> API: Success
            deactivate DB
            
            API --> UI: Chấm công thành công
            UI --> User: Hiển thị thông báo & Thông tin
        end
    end
    deactivate API

else Hết thời gian chớp mắt
    UI --> User: Hết thời gian, thử lại
end
deactivate UI

@enduml
