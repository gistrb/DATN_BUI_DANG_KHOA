@startuml
hide footbox
actor "Admin" as Admin
boundary "EmployeeListPage.jsx" as ListUI
control "employee_detail_api" as API
entity "NhanVien" as DB
entity "TaiKhoan" as Acc

Admin -> ListUI: Click nút "Xóa"
activate ListUI
ListUI --> Admin: Hộp thoại xác nhận?

Admin -> ListUI: Xác nhận Xóa
ListUI -> API: DELETE /api/employees/{id}/detail/
activate API

API -> DB: Lấy thông tin nhân viên
activate DB
DB --> API: Nhân viên
deactivate DB

alt Thành công
    API -> DB: Xóa bản ghi Nhân viên
    activate DB
    DB --> API: Success
    deactivate DB
    
    API -> Acc: Xóa tài khoản liên kết (nếu có)
    activate Acc
    Acc --> API: Success
    deactivate Acc
    
    API --> ListUI: {success: true}
    ListUI --> ListUI: Reload danh sách
    ListUI --> Admin: Danh sách đã cập nhật
else Lỗi
    API --> ListUI: {error: "Lỗi xóa..."}
    ListUI --> Admin: Hiển thị lỗi
end

deactivate API
deactivate ListUI

@enduml
